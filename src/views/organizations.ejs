<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>
    <p>Here are a few of our partner organizations:</p>

    <div class="org-grid">
        <% organizations.forEach(organization => { %>
            <div class="org-card">
                <div class="org-logo">
                    <img src="/images/<%= organization.logo_filename %>" alt="<%= organization.name %> logo">
                </div>
                <div class="org-info">
                    <h2><%= organization.name %></h2>
                    <p class="org-description"><%= organization.description %></p>
                    <a href="mailto:<%= organization.contact_email %>" class="org-email">
                        ✉ <%= organization.contact_email %>
                    </a>
                </div>
            </div>
        <% }); %>
    </div>
</main>

<%- include('partials/footer') %>
